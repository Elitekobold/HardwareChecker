<Window x:Class="HardwareInfoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hardware Info Viewer"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="20">
        <Grid x:Name="DetailViewGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20" LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="BackToListButton"
                            Content="Zurück"
                            Width="90"
                            Height="32"
                            Margin="0,0,10,0"
                            Visibility="Collapsed"
                            Click="BackToListButton_Click"/>
                    <Button Content="Gespeicherte Rechner"
                            Width="180"
                            Height="32"
                            Click="OpenSavedListButton_Click"/>
                </StackPanel>
                <Button Content="Speichern"
                        Width="141"
                        Height="32"
                        DockPanel.Dock="Right"
                        Click="Button_Click"/>
            </DockPanel>

            <TextBlock x:Name="DetailTitleText"
                       Text="System Hardware Information"
                       FontSize="24"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="0,8,0,20"
                       HorizontalAlignment="Center"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="InfoPanel" Orientation="Vertical" />
            </ScrollViewer>
        </Grid>

        <Grid x:Name="ListViewGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Content="Zurück zur aktuellen Detailansicht"
                    Width="250"
                    Height="32"
                    HorizontalAlignment="Left"
                    Click="CloseSavedListButton_Click"/>

            <ListBox x:Name="SavedComputersListBox"
                     Grid.Row="1"
                     Grid.Column="0"
                     Margin="0,15,10,15"
                     DisplayMemberPath="DisplayName"
                     SelectionChanged="SavedComputersListBox_SelectionChanged"/>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Margin="10,15,0,15"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="SavedComputerPreviewText"
                               Foreground="White"
                               FontSize="14"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <Button Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Content="Rechner öffnen"
                    Height="36"
                    Width="180"
                    HorizontalAlignment="Right"
                    Click="OpenSelectedComputerButton_Click"/>
        </Grid>
    </Grid>
</Window>
